# Paperpileのエクスポートファイルを指定します。
# Paperpile: Settings > Data and files > Export でJSONまたはBibTeXを書き出してください。
PAPERPILE_EXPORT_PATH=/path/to/paperpile-export.json

# 任意: 実行前にPaperpile exportを最新化するスクリプト
# PAPERPILE_SYNC_SCRIPT=/home/hiroki/Obsidian/scripts/sync_papers.sh

# 生成物の保存先
OUTPUT_DIR=./briefs
RAW_DIR=./raw
CHAT_DIR=./chat
STATE_DIR=./state
LOG_DIR=./logs

# 任意: MarkdownをObsidianにもコピーする
EXPORT_TO_OBSIDIAN=false
OBSIDIAN_EXPORT_DIR=/home/hiroki/Obsidian/intake/paperpile-briefs

# 任意: 生成後にgit commit/pushする
PUSH_TO_GIT=true
